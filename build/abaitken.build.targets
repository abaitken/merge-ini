<?xml version="1.0" encoding="utf-8"?>
<Project>
    <Target Name="_build_version">
        <PropertyGroup>
            <FullVersionString>$(VersionMajor).$(VersionMinor).$(VersionPatch)</FullVersionString>
            <FullVersionString Condition="'$(PreRelease)' != ''">$(FullVersionString)-$(PreRelease)</FullVersionString>
        </PropertyGroup>
    </Target>
    
    <Target Name="_set_properties">
        <PropertyGroup>
            <DefaultConfiguration>Release</DefaultConfiguration>
            <DefaultPlatform>Any CPU</DefaultPlatform>
        </PropertyGroup>
        
        <Warning Text="Configuration property not set. Using '$(DefaultConfiguration)' by default'" Condition="'$(Configuration)' == ''" />
        <Warning Text="Platform property not set. Using 'Any CPU' by default'" Condition="'$(Platform)' == ''" />
        
        <PropertyGroup>
            <Configuration Condition="'$(Configuration)' == ''">$(DefaultConfiguration)</Configuration>
            <Platform Condition="'$(Platform)' == ''">$(DefaultPlatform)</Platform>
        </PropertyGroup>
    </Target>
	
	<Target Name="CompileProjects" Condition="'@(BuildProjects)' != ''"
			DependsOnTargets="_set_properties">
		
		<MSBuild Projects="@(BuildProjects)" Targets="Build" BuildInParallel="true" 
				 Properties="Configuration=$(Configuration);
							 Platform=$(Platform)" />
							 
	</Target>
    
	<!--
		Cleans up all project types
	-->
	<Target Name="CleanProjects" 
			DependsOnTargets="CleanSource">		
	</Target>
	
	<!--
		Removes the build folders
	-->
	<Target Name="CleanFolders">
		<RemoveDir Directories="$(_IntermediateOutputPath);$(_OutDir)" />
	</Target>
	
	<!--
		Cleans up the compiled source projects
	-->
	<Target Name="CleanSource" Condition="'@(BuildProjects)' != ''"
			DependsOnTargets="_set_properties">
	
		<MSBuild Projects="@(BuildProjects)" Targets="Clean" BuildInParallel="true" 
				 Properties="Configuration=$(Configuration);
							 Platform=$(Platform)"
				 ContinueOnError="true" />
				 
	</Target>	


	<!--
		Stub for main Restore target
	-->
	<Target Name="Restore">
		<Exec Command='nuget restore "%(BuildProjects.Identity)"' />
    </Target>
	
	<!--
		Stub for main Build target
	-->
	<Target Name="Build" DependsOnTargets="CompileProjects">
	</Target>
		
	
	<!--
		Stub for main VSTest target
        DependsOnTargets="RunTests"
	-->
	<Target Name="VSTest">
        <Error Text="VSTest is not currently implemented" />
	</Target>
	
	<!--
		Stub for main Clean target
	-->
	<Target Name="Clean" DependsOnTargets="CleanProjects;CleanFolders">
	</Target>
	
	<!--
		Stub for main Pack target
	-->
	<Target Name="Pack" DependsOnTargets="Build">
		<Error Text="Pack is not currently implemented" />
	</Target>
    
	<!--
		Stub for main Publish target
	-->    
	<Target Name="Publish">
            
        <ItemGroup>
            <RuntimeIdentifiers Include="win-x64">
                <SelfContained>false</SelfContained>
            </RuntimeIdentifiers>
            <RuntimeIdentifiers Include="linux-x64">
                <SelfContained>true</SelfContained>
            </RuntimeIdentifiers>
        </ItemGroup>
		
		<MSBuild Projects="$(MSBuildProjectFile)" Targets="_publish_rid" BuildInParallel="true" 
				 Properties="RuntimeIdentifier=%(RuntimeIdentifiers.Identity);
                             SelfContained=%(RuntimeIdentifiers.SelfContained)" />
	</Target>
    
    <Target Name="_publish_rid" DependsOnTargets="_build_version">
        <PropertyGroup>
            <Configuration>Release</Configuration>
            <Platform>x64</Platform>
            
            <PublishRoot>$(MSBuildProjectDirectory)/publish</PublishRoot>
            
            <RidPublishDir>$(PublishRoot)/$(RuntimeIdentifier).$(FullVersionString)</RidPublishDir>
            <RidZipFile>$(PublishRoot)/$(ProjectIdentity).$(RuntimeIdentifier).$(FullVersionString).zip</RidZipFile>
        </PropertyGroup>
		
		<MSBuild Projects="@(PublicProjects)" Targets="Publish" 
				 Properties="Configuration=$(Configuration);
							 RuntimeIdentifier=$(RuntimeIdentifier);
                             PublishDir=$(RidPublishDir);
                             SelfContained=$(SelfContained);" />
                             
        <ZipDirectory SourceDirectory="$(RidPublishDir)"
                      DestinationFile="$(RidZipFile)" />
    </Target>
</Project>